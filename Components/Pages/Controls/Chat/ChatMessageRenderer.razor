@using Markdig
@using System.Text.RegularExpressions

<div class="chat-message-rendered">
    @((MarkupString)RenderedHtml)
</div>

@code {
    [Parameter] public string Content { get; set; } = "";

    private static readonly MarkdownPipeline Pipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().DisableHtml().Build();

    // Strip internal tool-invocation fenced blocks so the raw JSON tool
    // calls emitted by the model are never rendered to the user. Also drop
    // any draft prose that preceded the tool block — that text is scratch
    // reasoning written *before* the tool returned ground truth and should
    // never be shown alongside the corrected answer.
    private static readonly Regex ToolBlockWithLeadingProseRegex = new(
        @"\A[\s\S]*?```tool\s*[\s\S]*?```\s*", RegexOptions.IgnoreCase | RegexOptions.Compiled);
    private static readonly Regex ToolBlockRegex = new(
        @"```tool\s*[\s\S]*?```\s*", RegexOptions.IgnoreCase | RegexOptions.Compiled);

    private string RenderedHtml
    {
        get
        {
            if (string.IsNullOrEmpty(Content)) return "";
            // Drop the FIRST tool fence and everything before it (the draft),
            // then strip any remaining tool fences that appear later.
            var cleaned = ToolBlockWithLeadingProseRegex.Replace(Content, "");
            cleaned = ToolBlockRegex.Replace(cleaned, "");
            return Markdown.ToHtml(cleaned, Pipeline);
        }
    }
}

<style>
    .chat-message-rendered h1,
    .chat-message-rendered h2,
    .chat-message-rendered h3 { margin-top: .5rem; margin-bottom: .3rem; }
    .chat-message-rendered p { margin: .3rem 0; }
    .chat-message-rendered ul, .chat-message-rendered ol { margin: .3rem 0 .3rem 1.2rem; }
    .chat-message-rendered pre {
        background: #1e1e1e;
        color: #eaeaea;
        padding: .5rem;
        border-radius: 4px;
        overflow-x: auto;
    }
    .chat-message-rendered code {
        background: #f5f5f5;
        padding: .1rem .3rem;
        border-radius: 3px;
    }
    .chat-message-rendered blockquote {
        border-left: 3px solid #bbb;
        padding-left: .6rem;
        color: #555;
        margin: .4rem 0;
    }
    .chat-message-rendered table { border-collapse: collapse; margin: .4rem 0; }
    .chat-message-rendered th, .chat-message-rendered td {
        border: 1px solid #ccc; padding: .2rem .4rem;
    }
    .chat-message-rendered a { color: #0a66c2; text-decoration: underline; }
</style>
