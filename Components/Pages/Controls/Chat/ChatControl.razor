@using AIStoryBuilders.AI
@using AIStoryBuilders.Models
@using AIStoryBuilders.Services
@inherits OwningComponentBase
@inject NotificationService NotificationService
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<RadzenCard Style="display:flex; flex-direction:column; height: 480px; max-height: calc(100vh - 180px);">
    <div style="display:flex; gap:.5rem; align-items:center; margin-bottom:.5rem;">
        <RadzenText TextStyle="TextStyle.H6" Style="flex:1;">Story Chat</RadzenText>
        <RadzenButton Text="Clear" Icon="refresh" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" Click="ClearConversation" />
    </div>

    <div style="flex:1; overflow-y:auto; padding:.5rem; background:#fafafa; border-radius:4px;" @ref="_scrollContainer">
        @foreach (var m in _session?.Messages ?? new List<AIStoryBuilders.Models.ChatDisplayMessage>())
        {
            <div class="@(m.Role == "user" ? "chat-bubble user" : "chat-bubble assistant")">
                <strong>@(m.Role == "user" ? "You" : "Assistant")</strong>
                <ChatMessageRenderer Content="@m.Content" />
            </div>
        }
        @if (_isStreaming)
        {
            <div class="chat-bubble assistant">
                <strong>Assistant</strong>
                @if (string.IsNullOrWhiteSpace(_streamingBuffer))
                {
                    <div class="typing-indicator" aria-label="Assistant is thinking">
                        <span></span><span></span><span></span>
                    </div>
                }
                else
                {
                    <ChatMessageRenderer Content="@_streamingBuffer" />
                }
            </div>
        }
    </div>

    <div style="display:flex; gap:.5rem; margin-top:.5rem; align-items:stretch; position:relative;">
        <div style="flex:1; position:relative;" @ref="_inputWrapper">
            <RadzenTextArea @bind-Value="_currentInput" @onkeydown="HandleKeyDown" Placeholder="Ask about the story or request changes..." Rows="2" Style="width:100%;" Disabled="_isStreaming" />
            @if (_isStreaming)
            {
                <div class="chat-input-thinking" aria-label="Assistant is thinking">
                    <div class="typing-indicator">
                        <span></span><span></span><span></span>
                    </div>
                    <span class="chat-input-thinking-text">Thinking…</span>
                </div>
            }
        </div>
        <RadzenButton Text="Send" Icon="send" ButtonStyle="ButtonStyle.Primary" Click="SendMessage" Disabled="_isStreaming" />
    </div>
</RadzenCard>

<style>
    .chat-bubble { background:#fff; border-radius:6px; padding:.5rem .75rem; margin-bottom:.5rem; box-shadow:0 1px 2px rgba(0,0,0,.05); }
    .chat-bubble.user { background:#e8f0fe; }
    .chat-bubble.assistant { background:#fff; }

    .typing-indicator { display:inline-flex; gap:4px; padding:.4rem .2rem; align-items:center; }
    .typing-indicator span {
        width: 7px; height: 7px; border-radius: 50%;
        background: #8a8a8a; display: inline-block;
        animation: typing-bounce 1.2s infinite ease-in-out both;
    }
    .typing-indicator span:nth-child(1) { animation-delay: -0.32s; }
    .typing-indicator span:nth-child(2) { animation-delay: -0.16s; }
    @@keyframes typing-bounce {
        0%, 80%, 100% { transform: scale(0.6); opacity: .4; }
        40% { transform: scale(1); opacity: 1; }
    }

    .chat-input-thinking {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        display: flex;
        align-items: center;
        gap: .4rem;
        background: rgba(255,255,255,.85);
        padding: .25rem .6rem;
        border-radius: 999px;
        box-shadow: 0 1px 3px rgba(0,0,0,.08);
        pointer-events: none;
        font-size: .85rem;
        color: #555;
    }
    .chat-input-thinking-text { font-style: italic; }
</style>

@code {
    [Parameter] public Story objStory { get; set; }

    private IStoryChatService ChatService;
    private AIStoryBuildersService StoryService;
    private IGraphBuilder GraphBuilder;

    private string _sessionId = Guid.NewGuid().ToString();
    private AIStoryBuilders.Models.ConversationSession _session;
    private string _currentInput = "";
    private string _streamingBuffer = "";
    private bool _isStreaming;
    private ElementReference _scrollContainer;
    private ElementReference _inputWrapper;

    protected override void OnInitialized()
    {
        ChatService = (IStoryChatService)ScopedServices.GetService(typeof(IStoryChatService));
        StoryService = (AIStoryBuildersService)ScopedServices.GetService(typeof(AIStoryBuildersService));
        GraphBuilder = (IGraphBuilder)ScopedServices.GetService(typeof(IGraphBuilder));

        if (objStory != null)
        {
            ChatService.SetActiveStory(objStory);
        }
        _session = ChatService.GetOrCreateSession(_sessionId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("chatInput.bindEnter", _inputWrapper);
            }
            catch
            {
                // Non-fatal: Enter will still send via the Blazor handler,
                // it just won't suppress the newline in the textarea.
            }
        }
    }

    public async Task BuildGraph()
    {
        if (objStory == null) return;
        try
        {
            await StoryService.EnsureGraphExistsAsync(objStory.Title, GraphBuilder);
            ChatService.SetActiveStory(GraphState.CurrentStory ?? objStory);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Graph build error",
                Detail = ex.Message,
                Duration = 4000
            });
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_currentInput)) return;
        var msg = _currentInput.TrimEnd('\r', '\n', ' ', '\t');
        _currentInput = "";
        _isStreaming = true;
        _streamingBuffer = "";

        StateHasChanged();

        try
        {
            await foreach (var chunk in ChatService.SendMessageAsync(msg, _sessionId))
            {
                _streamingBuffer += chunk;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _session.Messages.Add(new AIStoryBuilders.Models.ChatDisplayMessage
            {
                Role = "assistant",
                Content = $"**Error:** {ex.Message}"
            });
        }
        finally
        {
            _streamingBuffer = "";
            _isStreaming = false;
            StateHasChanged();
        }
    }

    private void ClearConversation()
    {
        ChatService.ClearSession(_sessionId);
        _session = ChatService.GetOrCreateSession(_sessionId);
        StateHasChanged();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Enter (without Shift) sends the message; Shift+Enter inserts a newline.
        if (e.Key == "Enter" && !e.ShiftKey && !_isStreaming)
        {
            await SendMessage();
        }
    }
}
